.selection-button {
    width: 250px;
    height: 180px;
    margin: 15px;
    border-width: 4px;
    border-color: white;
    border-radius: 15px;
    background-color: rgba(255, 255, 255, 0.1);
    transition-property: scale, border-color, background-color;
    transition-duration: 0.2s;
    overflow: hidden;
    padding: 0;
}

.selection-button:hover {
    scale: 1.05;
    border-color: #FFD700;
    background-color: rgba(255, 255, 255, 0.2);
}

.selection-button:active {
    scale: 0.95;
}

.thumbnail-image {
    width: 100%;
    height: 100%;
    -unity-background-scale-mode: scale-to-fit;
}

.button-label {
    position: absolute;
    bottom: 5px;
    left: 0;
    right: 0;
    -unity-text-align: middle-center;
    background-color: rgba(0, 0, 0, 0.6);
    color: white;
    font-size: 14px;
    opacity: 0;
    transition-property: opacity;
    transition-duration: 0.2s;
}

.selection-button:hover .button-label {
    opacity: 1;
}

#ImageGrid .unity-scroll-view__content-container {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    padding: 20px;
}
