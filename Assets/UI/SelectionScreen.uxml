<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project:/Assets/UI/SelectionScreen.uss" />
    <ui:VisualElement style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.9); align-items: center; justify-content: center; padding: 30px;">
        <ui:Label text="JIGSAW PUZZLE" style="font-size: 50px; color: gold; -unity-font-style: bold; margin-bottom: 5px;" />
        <ui:Label text="パズル画像と難易度を選択" style="font-size: 20px; color: white; margin-bottom: 25px;" />
        
        <!-- 枚数選択セクション -->
        <ui:VisualElement style="flex-direction: row; align-items: center; justify-content: center; margin-bottom: 30px; background-color: rgba(255, 255, 255, 0.1); padding: 10px; border-radius: 10px;">
            <ui:Label text="ピース数:" style="color: white; font-size: 16px; margin-right: 15px;" />
            <ui:RadioButtonGroup name="PieceCountGroup" value="1" style="flex-direction: row;">
                <ui:RadioButton label="24枚 (初級)" name="pieces-24" />
                <ui:RadioButton label="96枚 (中級)" name="pieces-96" />
                <ui:RadioButton label="216枚 (上級)" name="pieces-216" />
                <ui:RadioButton label="486枚 (超難問)" name="pieces-486" />
            </ui:RadioButtonGroup>
        </ui:VisualElement>

        <ui:ScrollView name="ImageGrid" mode="Vertical" style="width: 90%; height: 60%; background-color: rgba(255, 255, 255, 0.05); border-radius: 20px;" />

        
        <ui:Label text="画像をクリックしてスタート！" style="margin-top: 20px; color: rgba(255, 255, 255, 0.5); font-size: 16px;" />
        <ui:Label text="Ver 1.1" style="position: absolute; right: 20px; bottom: 20px; color: rgba(255, 255, 255, 0.3); font-size: 14px;" />
    </ui:VisualElement>

    <!-- 確認ダイアログオーバーレイ -->
    <ui:VisualElement name="ConfirmationOverlay" style="position: absolute; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.85); align-items: center; justify-content: center; display: none;">
        <ui:VisualElement name="ConfirmationCard" style="width: 450px; padding: 30px; background-color: rgba(40, 40, 40, 1); border-width: 2px; border-color: gold; border-radius: 20px; align-items: center;">
            <ui:Label text="この設定でパズルを開始しますか？" style="font-size: 24px; color: white; margin-bottom: 20px; -unity-font-style: bold;" />
            
            <ui:VisualElement name="ConfirmImage" style="width: 320px; height: 180px; border-radius: 10px; border-width: 2px; border-color: white; margin-bottom: 15px; background-color: black; -unity-background-scale-mode: scale-to-fit;" />
            
            <ui:Label name="ConfirmPieces" text="ピース数: 96枚" style="font-size: 20px; color: #FFD700; margin-bottom: 30px;" />

            <ui:VisualElement style="flex-direction: row; justify-content: space-around; width: 100%;">
                <ui:Button name="ConfirmYes" text="はい（開始）" class="confirm-button yes" style="width: 160px; height: 50px; font-size: 18px;" />
                <ui:Button name="ConfirmNo" text="いいえ（戻る）" class="confirm-button no" style="width: 160px; height: 50px; font-size: 18px;" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>